---
// AgentsTable.astro — Tabela de agentes e modelos
// Dados do snapshot (/api/snapshot), fetch no cliente
// Refinado: hover, alinhamento, monoespaçado consistente
---

<div class="metric-card">
  <div class="section-title">Agentes</div>

  <div id="agents-content">
    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      <span class="skeleton-text short"></span>
    </div>
  </div>
</div>

<script>
(async function() {
  const el = document.getElementById('agents-content');
  if (!el) return;

  try {
    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    const agents = snap.agents || {};
    const models = snap.models || {};

    if (Object.keys(agents).length === 0) {
      el.innerHTML = `
        <div class="empty-state">
          <div class="empty-state-icon">&#x1F916;</div>
          <div class="empty-state-title">Nenhum agente registrado</div>
          <div class="empty-state-text">Agentes aparecem ap&oacute;s chamadas de subagentes (Explore, General) durante as tarefas.</div>
        </div>`;
      return;
    }

    let html = `<table class="data-table">
      <tr><th>Tipo</th><th class="cell-right">Chamadas</th></tr>`;

    for (const [agent, count] of Object.entries(agents).sort((a, b) => b[1] - a[1])) {
      html += `<tr>
        <td class="cell-mono">${agent}</td>
        <td class="cell-right cell-mono">${count}</td>
      </tr>`;
    }
    html += `</table>`;

    // Modelos
    if (Object.keys(models).length > 0) {
      html += `<div class="section-title" style="margin-top: 1rem;">Modelos</div>`;
      html += `<table class="data-table">
        <tr><th>Modelo</th><th class="cell-right">Usos</th></tr>`;
      for (const [model, count] of Object.entries(models).sort((a, b) => b[1] - a[1])) {
        html += `<tr>
          <td class="cell-mono" style="font-size: 0.8rem;">${model}</td>
          <td class="cell-right cell-mono">${count}</td>
        </tr>`;
      }
      html += `</table>`;
    }

    el.innerHTML = html;

  } catch (e) {
    el.innerHTML = `<p style="color: #ef4444; font-family: var(--font-mono); font-size: 0.8rem; padding: 0.5rem 0;">
      Erro ao carregar agentes.
    </p>`;
  }
})();
</script>
