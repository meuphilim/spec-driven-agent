---
// AgentsTable.astro — Tabela de agentes e modelos
// Dados do snapshot (/api/snapshot), fetch no cliente
---

<div class="metric-card card-enter">
  <div class="section-title">Agentes &amp; Modelos</div>

  <div id="agents-content">
    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      <span class="skeleton-text"></span>
      <span class="skeleton-text long"></span>
      <span class="skeleton-text short"></span>
    </div>
  </div>
</div>

<script>
(async function() {
  const el = document.getElementById('agents-content');
  if (!el) return;

  try {
    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    const agents = snap.agents || {};
    const models = snap.models || {};

    if (Object.keys(agents).length === 0) {
      el.innerHTML = `
        <div class="empty-state" style="padding: 1.75rem 0.5rem;">
          <div class="empty-state-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text-faint);">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <div class="empty-state-title">Nenhum agente registrado</div>
          <div class="empty-state-text">Agentes aparecem ap&oacute;s chamadas de subagentes (Explore, General) durante as tarefas.</div>
        </div>`;
      return;
    }

    const agentEntries = Object.entries(agents).sort((a, b) => b[1] - a[1]);
    const maxCalls = agentEntries[0][1];

    // Agents com mini bar visual
    let html = `
      <div style="display: flex; flex-direction: column;">`;

    for (const [agent, count] of agentEntries) {
      const pct = Math.round((count / maxCalls) * 100);
      html += `
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid var(--border-subtle); transition: background-color var(--transition-base);">
          <span style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-secondary); min-width: 6rem;">${agent}</span>
          <div class="skill-bar-track" style="height: 3px;">
            <div class="skill-bar-fill" style="width: ${pct}%;"></div>
          </div>
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); min-width: 2rem; text-align: right;">${count}</span>
        </div>`;
    }
    html += `</div>`;

    // Modelos (tabela compacta)
    if (Object.keys(models).length > 0) {
      html += `
        <div style="border-top: 1px solid var(--border-subtle); margin-top: 1rem; padding-top: 1rem;">
          <div class="section-title" style="margin-bottom: 0.625rem;">Modelos</div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Modelo</th>
                <th class="cell-right">Usos</th>
              </tr>
            </thead>
            <tbody>`;

      for (const [model, count] of Object.entries(models).sort((a, b) => b[1] - a[1])) {
        // Trunca nomes longos de modelo
        const displayModel = model.length > 32 ? model.slice(0, 29) + '&hellip;' : model;
        html += `
          <tr>
            <td class="cell-mono" style="font-size: 0.75rem; color: var(--text-secondary);" title="${model}">${displayModel}</td>
            <td class="cell-right cell-mono">${count}</td>
          </tr>`;
      }

      html += `
            </tbody>
          </table>
        </div>`;
    }

    el.innerHTML = html;

  } catch (e) {
    el.innerHTML = `
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 0; color: #f87171; font-family: var(--font-mono); font-size: 0.78rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Erro ao carregar agentes.
      </div>`;
  }
})();
</script>
