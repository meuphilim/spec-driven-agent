---
// HistoryPanel.astro — Tarefas, skills, tempo
// Dados do snapshot (/api/snapshot), fetch no cliente
// Skills com barras gradientes reais
---

<div class="metric-card">
  <div class="section-title">Hist&oacute;rico</div>

  <div id="history-content">
    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      <span class="skeleton-text"></span>
      <span class="skeleton-text short"></span>
    </div>
  </div>
</div>

<script>
(async function() {
  const el = document.getElementById('history-content');
  if (!el) return;

  try {
    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    if (snap.empty || !snap.tasks || snap.tasks.total === 0) {
      el.innerHTML = `
        <div class="empty-state">
          <div class="empty-state-icon">&#x1F4CA;</div>
          <div class="empty-state-title">Nenhum dado ainda</div>
          <div class="empty-state-text">M&eacute;tricas aparecem ap&oacute;s a primeira tarefa ser conclu&iacute;da.</div>
        </div>`;
      return;
    }

    const tasks = snap.tasks;
    const dur = formatDuration(snap.time_spent_s);

    let html = `
      <div class="stats-grid">
        <div class="stat-block">
          <div class="metric-label">Tarefas</div>
          <div class="metric-value">${tasks.total}</div>
          <div style="margin-top: 0.2rem;">
            <span class="badge-success">${tasks.success} sucesso</span>
            ${tasks.failed > 0 ? `<span class="badge-fail">${tasks.failed} falha</span>` : ''}
          </div>
        </div>
        <div class="stat-block">
          <div class="metric-label">Sess&otilde;es</div>
          <div class="metric-value">${snap.sessions || 0}</div>
        </div>
        <div class="stat-block">
          <div class="metric-label">Tempo</div>
          <div class="metric-value">${dur}</div>
        </div>
      </div>`;

    // Skills (top 8) with gradient bars
    const skills = snap.skills || {};
    const skillEntries = Object.entries(skills).sort((a, b) => b[1] - a[1]).slice(0, 8);
    if (skillEntries.length > 0) {
      const maxCount = skillEntries[0][1];
      html += `<div class="section-title" style="margin-top: 0.5rem;">Skills</div>`;
      for (const [skill, count] of skillEntries) {
        const pct = Math.round((count / maxCount) * 100);
        html += `
          <div class="skill-row">
            <span class="skill-name">${skill}</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: ${pct}%;"></div>
            </div>
            <span class="skill-count">${count}</span>
          </div>`;
      }
    }

    el.innerHTML = html;

  } catch (e) {
    el.innerHTML = `<p style="color: #ef4444; font-family: var(--font-mono); font-size: 0.8rem; padding: 0.5rem 0;">
      Erro ao carregar dados.
    </p>`;
  }
})();

function formatDuration(seconds) {
  if (!seconds || seconds === 0) return '0s';
  if (seconds < 60) return seconds + 's';
  if (seconds < 3600) return Math.floor(seconds / 60) + 'm ' + (seconds % 60) + 's';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h + 'h ' + m + 'm';
}
</script>
