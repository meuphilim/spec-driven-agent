---
// HistoryPanel.astro — Tarefas, skills, tempo
// Dados do snapshot (/api/snapshot), fetch no cliente
---

<div class="metric-card card-enter">
  <div class="section-title">Hist&oacute;rico de Atividade</div>

  <div id="history-content">
    <div style="display: flex; flex-direction: column; gap: 0.6rem;">
      <span class="skeleton-text long"></span>
      <span class="skeleton-text"></span>
      <span class="skeleton-text short"></span>
    </div>
  </div>
</div>

<script>
(async function() {
  const el = document.getElementById('history-content');
  if (!el) return;

  try {
    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    if (snap.empty || !snap.tasks || snap.tasks.total === 0) {
      el.innerHTML = `
        <div class="empty-state" style="padding: 2rem 0.5rem;">
          <div class="empty-state-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text-faint);">
              <path d="M3 3v18h18"/><path d="M18 9l-5 5-4-4-3 3"/>
            </svg>
          </div>
          <div class="empty-state-title">Nenhum dado ainda</div>
          <div class="empty-state-text">M&eacute;tricas aparecem ap&oacute;s a primeira tarefa ser conclu&iacute;da.</div>
        </div>`;
      return;
    }

    const tasks = snap.tasks;
    const dur = formatDuration(snap.time_spent_s);

    // Stats grid
    let html = `
      <div class="stats-grid">
        <div class="stat-block">
          <div class="metric-label">Tarefas</div>
          <div class="metric-value" style="font-size: 1.5rem;">${tasks.total}</div>
          <div style="margin-top: 0.35rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span class="badge-success">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              ${tasks.success}
            </span>
            ${tasks.failed > 0 ? `<span class="badge-fail">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              ${tasks.failed}
            </span>` : ''}
          </div>
        </div>
        <div class="stat-block">
          <div class="metric-label">Sess&otilde;es</div>
          <div class="metric-value" style="font-size: 1.5rem;">${snap.sessions || 0}</div>
        </div>
        <div class="stat-block">
          <div class="metric-label">Tempo</div>
          <div class="metric-value" style="font-size: 1.5rem; letter-spacing: -0.05em;">${dur}</div>
        </div>
      </div>`;

    // Skills section
    const skills = snap.skills || {};
    const skillEntries = Object.entries(skills).sort((a, b) => b[1] - a[1]).slice(0, 8);
    if (skillEntries.length > 0) {
      const maxCount = skillEntries[0][1];
      html += `
        <div style="border-top: 1px solid var(--border-subtle); padding-top: 1rem; margin-top: 0.25rem;">
          <div class="section-title" style="margin-bottom: 0.75rem;">Skills utilizadas</div>
          <div style="display: flex; flex-direction: column; gap: 0.1rem;">`;

      for (const [skill, count] of skillEntries) {
        const pct = Math.round((count / maxCount) * 100);
        html += `
          <div class="skill-row">
            <span class="skill-name">${skill}</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: ${pct}%;"></div>
            </div>
            <span class="skill-count">${count}</span>
          </div>`;
      }

      html += `</div></div>`;
    }

    el.innerHTML = html;

  } catch (e) {
    el.innerHTML = `
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 0; color: #f87171; font-family: var(--font-mono); font-size: 0.78rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Erro ao carregar dados.
      </div>`;
  }
})();

function formatDuration(seconds) {
  if (!seconds || seconds === 0) return '0s';
  if (seconds < 60) return seconds + 's';
  if (seconds < 3600) return Math.floor(seconds / 60) + 'm ' + (seconds % 60) + 's';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h + 'h ' + m + 'm';
}
</script>
