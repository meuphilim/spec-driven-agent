---
// TokenChart.astro — Gráfico de tokens (Chart.js via CDN)
// Breakdown input/output/cache — Chart.js minimalista, sem bordas desnecessárias
---

<div class="metric-card card-enter">
  <div class="section-title">Tokens por Categoria</div>

  <div class="chart-wrapper">
    <canvas id="token-chart"></canvas>
  </div>

  <div id="chart-status">
    <div style="display: flex; align-items: center; gap: 0.5rem; padding-top: 0.5rem;">
      <span class="skeleton-text short" style="height: 0.6rem;"></span>
    </div>
  </div>
</div>

<script>
(async function() {
  const canvas = document.getElementById('token-chart');
  const status = document.getElementById('chart-status');
  if (!canvas || !status) return;

  try {
    await loadChartJs();

    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    if (!snap.tokens_available || !snap.tokens || snap.tokens.total === 0) {
      // Oculta canvas, mostra estado vazio
      canvas.style.display = 'none';
      status.innerHTML = `
        <div class="empty-state" style="padding: 1.5rem 0.5rem;">
          <div class="empty-state-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text-faint);">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <div class="empty-state-title">Tokens indispon&iacute;vel</div>
          <div class="empty-state-text">Dados de token s&oacute; dispon&iacute;veis para chamadas de subagentes (Agent tool).</div>
        </div>`;
      return;
    }

    const t = snap.tokens;

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: ['Input', 'Output', 'Cache Write', 'Cache Read'],
        datasets: [
          {
            label: 'Tokens',
            data: [t.input || 0, t.output || 0, t.cache_write || 0, t.cache_read || 0],
            backgroundColor: [
              'rgba(132, 204, 22, 0.85)',
              'rgba(163, 230, 53, 0.75)',
              'rgba(101, 163, 13, 0.65)',
              'rgba(77, 124, 15, 0.55)',
            ],
            borderColor: [
              'rgba(132, 204, 22, 0.0)',
              'rgba(163, 230, 53, 0.0)',
              'rgba(101, 163, 13, 0.0)',
              'rgba(77, 124, 15, 0.0)',
            ],
            borderWidth: 0,
            borderRadius: 6,
            borderSkipped: false,
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        layout: {
          padding: { top: 4, bottom: 0 }
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: 'rgba(9,9,11,0.95)',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            titleFont: { family: 'JetBrains Mono, monospace', size: 10, weight: '600' },
            bodyFont: { family: 'JetBrains Mono, monospace', size: 10 },
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              title: function(items) {
                return items[0].label;
              },
              label: function(ctx) {
                return '  ' + Number(ctx.raw).toLocaleString('pt-BR') + ' tokens';
              }
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: '#52525b',
              font: { family: 'JetBrains Mono, monospace', size: 9 },
              padding: 6,
            },
            grid: { display: false },
            border: { display: false }
          },
          y: {
            ticks: {
              color: '#52525b',
              font: { family: 'JetBrains Mono, monospace', size: 9 },
              padding: 8,
              maxTicksLimit: 5,
              callback: function(value) {
                if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                if (value >= 1000) return (value / 1000).toFixed(0) + 'K';
                return value;
              }
            },
            grid: {
              color: 'rgba(255,255,255,0.04)',
              lineWidth: 1,
            },
            border: { display: false, dash: [4, 4] }
          }
        },
        animation: {
          duration: 700,
          easing: 'easeOutQuart',
        }
      }
    });

    const totalFormatted = t.total.toLocaleString('pt-BR');
    const inputPct = t.total > 0 ? Math.round((t.input / t.total) * 100) : 0;
    const cachePct = t.total > 0 ? Math.round(((t.cache_read + t.cache_write) / t.total) * 100) : 0;

    status.innerHTML = `
      <div class="chart-total-overlay">
        <span style="color: var(--text-secondary); font-size: 0.75rem; font-weight: 600; letter-spacing: -0.02em; font-family: var(--font-mono);">${totalFormatted}</span>
        <span style="margin-left: 0.4rem; color: var(--text-faint);">total &nbsp;&middot;&nbsp; ${inputPct}% input &nbsp;&middot;&nbsp; ${cachePct}% cache</span>
      </div>`;

  } catch (e) {
    canvas.style.display = 'none';
    status.innerHTML = `
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 0; color: #f87171; font-family: var(--font-mono); font-size: 0.78rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Erro ao carregar gr&aacute;fico.
      </div>`;
  }
})();

function loadChartJs() {
  return new Promise((resolve, reject) => {
    if (typeof Chart !== 'undefined') { resolve(); return; }
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    script.onload = resolve;
    script.onerror = reject;
    document.head.appendChild(script);
  });
}
</script>
