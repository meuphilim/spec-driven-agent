---
// TokenChart.astro — Gráfico de tokens (Chart.js via CDN)
// Mostra breakdown input/output/cache como stacked horizontal
// Daily data TBD — por enquanto exibe total agregado
---

<div class="metric-card">
  <div class="section-title">Tokens</div>

  <div style="position: relative; height: 180px;">
    <canvas id="token-chart"></canvas>
  </div>

  <div id="chart-status" style="text-align: center; margin-top: 0.5rem;">
    <span style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">
      Carregando gr&aacute;fico...
    </span>
  </div>
</div>

<script>
(async function() {
  const canvas = document.getElementById('token-chart');
  const status = document.getElementById('chart-status');
  if (!canvas || !status) return;

  try {
    await loadChartJs();

    const res = await fetch('/api/snapshot');
    const snap = await res.json();

    if (!snap.tokens_available || !snap.tokens || snap.tokens.total === 0) {
      status.innerHTML = `
        <div style="display: flex; flex-direction: column; gap: 0.3rem; align-items: center; padding: 0.5rem 0;">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
            Tokens: indispon&iacute;vel
          </span>
          <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-faint);">
            Dados de token s&oacute; para chamadas de subagentes (Agent tool)
          </span>
        </div>`;
      return;
    }

    const t = snap.tokens;

    // Stacked horizontal bar chart: input vs output vs cache
    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: ['Total'],
        datasets: [
          {
            label: 'Input',
            data: [t.input || 0],
            backgroundColor: '#84cc16',
            borderRadius: 3,
          },
          {
            label: 'Output',
            data: [t.output || 0],
            backgroundColor: '#a3e635',
            borderRadius: 3,
          },
          {
            label: 'Cache Write',
            data: [t.cache_write || 0],
            backgroundColor: '#65a30d',
            borderRadius: 3,
          },
          {
            label: 'Cache Read',
            data: [t.cache_read || 0],
            backgroundColor: '#4d7c0f',
            borderRadius: 3,
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              color: '#64748b',
              font: { family: 'JetBrains Mono, monospace', size: 9 },
              boxWidth: 10,
              padding: 12,
            }
          },
          tooltip: {
            backgroundColor: 'rgba(10,10,10,0.9)',
            titleFont: { family: 'JetBrains Mono, monospace', size: 11 },
            bodyFont: { family: 'JetBrains Mono, monospace', size: 10 },
            padding: 8,
            callbacks: {
              label: function(ctx) {
                return ctx.dataset.label + ': ' + Number(ctx.raw).toLocaleString('pt-BR');
              }
            }
          }
        },
        scales: {
          x: {
            ticks: { color: '#475569', font: { size: 9 } },
            grid: { display: false }
          },
          y: {
            ticks: {
              color: '#475569',
              font: { size: 9 },
              callback: function(value) {
                if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                if (value >= 1000) return (value / 1000).toFixed(0) + 'K';
                return value;
              }
            },
            grid: { color: 'rgba(255,255,255,0.04)' }
          }
        }
      }
    });

    // Legend abaixo com valores
    const totalFormatted = t.total.toLocaleString('pt-BR');
    status.innerHTML = `<span style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.65rem;">
      Total: ${totalFormatted} tokens
    </span>`;

  } catch (e) {
    status.innerHTML = `<span style="color: #ef4444; font-family: var(--font-mono); font-size: 0.75rem;">
      Erro ao carregar gr&aacute;fico.
    </span>`;
  }
})();

function loadChartJs() {
  return new Promise((resolve, reject) => {
    if (typeof Chart !== 'undefined') { resolve(); return; }

    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    script.onload = resolve;
    script.onerror = reject;
    document.head.appendChild(script);
  });
}
</script>
