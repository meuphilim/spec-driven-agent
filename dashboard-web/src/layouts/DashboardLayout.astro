---
// DashboardLayout.astro — Layout principal do dashboard web
// Tema escuro fixo, navbar refinada, grid responsivo 2-col
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Dashboard &mdash; Spec-Driven Agent</title>
  </head>
  <body class="dark">
    <!-- Navbar -->
    <header class="navbar">
      <span class="navbar-brand">sda</span>
      <span class="navbar-divider"></span>
      <span class="navbar-title">Dashboard</span>
      <span class="navbar-spacer"></span>
      <span class="navbar-indicator" id="live-indicator">
        <span class="live-dot"></span>
        AO VIVO
      </span>
      <span class="navbar-badge">v5.2.0</span>
    </header>

    <!-- Main content -->
    <main style="
      max-width: 1200px; margin: 0 auto;
      padding: 1.5rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    ">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="
      text-align: center; padding: 1.5rem 2rem 2.5rem;
      font-family: var(--font-mono); font-size: 0.65rem;
      color: var(--text-faint);
      letter-spacing: 0.05em;
    ">
      Spec-Driven Agent &middot; Dados locais &middot; Zero telemetria
    </footer>

    <style>
      @media (max-width: 768px) {
        main { grid-template-columns: 1fr !important; }
      }
    </style>
  </body>
</html>
