---
// index.astro — Página única do dashboard
// Fetch dos dados no build (static) + hidratação cliente via SSE
import DashboardLayout from "../layouts/DashboardLayout.astro";
import LiveHeader from "../components/LiveHeader.astro";
import HistoryPanel from "../components/HistoryPanel.astro";
import EconomyCard from "../components/EconomyCard.astro";
import AgentsTable from "../components/AgentsTable.astro";
import TokenChart from "../components/TokenChart.astro";
import EmptyState from "../components/EmptyState.astro";
---

<DashboardLayout>
  <!-- Coluna da esquerda (ou única em mobile) -->
  <section style="display: flex; flex-direction: column; gap: 1rem;">
    <LiveHeader />
    <HistoryPanel />
    <AgentsTable />
  </section>

  <!-- Coluna da direita -->
  <section style="display: flex; flex-direction: column; gap: 1rem;">
    <EconomyCard />
    <TokenChart />
  </section>
</DashboardLayout>

<!-- SSE client -->
<script>
  import "../lib/sse.js";
</script>
