---
---

<section class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl p-8 sm:p-12 md:p-16 text-center cta-card">
      <div class="cta-glow absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full blur-3xl pointer-events-none" />

      <div class="relative">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full cta-badge">
          <span class="w-2 h-2 rounded-full bg-accent-400" />
          <span class="text-xs font-mono text-accent-400 font-medium">MIT License · Open Source</span>
        </div>

        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight" style="color: var(--text-primary);">
          Ready to bring <span class="gradient-text">discipline</span><br />
          to your agent workflow?
        </h2>

        <p class="mt-6 text-lg max-w-xl mx-auto" style="color: var(--text-secondary);">
          Install spec-driven-agent and let Samantha orchestrate your next development cycle.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://www.npmjs.com/package/spec-driven-agent" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-8 py-4 bg-accent-500 hover:bg-accent-400 text-gray-950 font-semibold text-sm rounded-lg transition-all duration-200 shadow-lg shadow-accent-500/25 hover:shadow-accent-400/40">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
            npm install -g spec-driven-agent
          </a>
          <a href="https://github.com/meuphilim/spec-driven-agent" target="_blank" rel="noopener noreferrer"
             class="cta-gh-btn inline-flex items-center gap-2 px-8 py-4 text-sm rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Star on GitHub
          </a>
        </div>

        <div class="mt-8 flex items-center justify-center gap-6 text-xs" style="color: var(--text-muted);">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            53 tests passing
          </span>
          <span>Node ≥ 18</span>
          <span>MIT</span>
          <span>Claude Code</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    background: linear-gradient(135deg,
      color-mix(in srgb, #84cc16 5%, var(--bg-muted)),
      var(--bg-page),
      color-mix(in srgb, #84cc16 3%, var(--bg-muted))
    );
    border: 1px solid color-mix(in srgb, #84cc16 18%, transparent);
  }
  .cta-glow {
    background: color-mix(in srgb, #84cc16 6%, transparent);
  }
  .cta-badge {
    background-color: color-mix(in srgb, #84cc16 10%, transparent);
    border: 1px solid color-mix(in srgb, #84cc16 20%, transparent);
  }
  .cta-gh-btn {
    color: var(--text-secondary);
    border: 1px solid var(--border-default);
  }
  .cta-gh-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-strong);
  }
</style>
