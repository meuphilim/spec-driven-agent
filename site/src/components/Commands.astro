---
interface Command {
  cmd: string;
  desc: string;
  badge?: string;
}

const commands: Command[] = [
  { cmd: 'npx sda init', desc: 'Initialize SDD in your project', badge: 'setup' },
  { cmd: 'npx sda session "feat: ..."', desc: 'Start a new SDD session', badge: 'core' },
  { cmd: 'npx sda task "add login page"', desc: 'Quick task (LITE mode auto)', badge: 'core' },
  { cmd: 'sda /spec', desc: 'Generate specification with acceptance criteria', badge: 'phase' },
  { cmd: 'sda /design', desc: 'Architecture design phase', badge: 'phase' },
  { cmd: 'sda /plan', desc: 'Generate implementation plan', badge: 'phase' },
  { cmd: 'sda /implement', desc: 'Execute plan step by step', badge: 'execute' },
  { cmd: 'sda /review', desc: 'Code review against spec', badge: 'validate' },
  { cmd: 'sda /reflect', desc: 'Auto-evaluation and knowledge consolidation', badge: 'reflect' },
  { cmd: 'sda /status', desc: 'Show current session state', badge: 'info' },
  { cmd: 'sda /context', desc: 'Load project constitution', badge: 'info' },
  { cmd: 'sda /debug', desc: 'Investigate bugs systematically', badge: 'debug' },
  { cmd: 'sda /estimate', desc: 'Estimate effort for ambiguous tasks', badge: 'plan' },
  { cmd: 'sda /socrates', desc: 'Challenge assumptions before building', badge: 'design' },
  { cmd: 'sda /learn', desc: 'Register pattern/heuristic/antipattern', badge: 'reflect' },
];

const badgeColors: Record<string, string> = {
  setup: 'bg-gray-500/10 text-gray-400 border-gray-500/20',
  core: 'bg-accent-500/10 text-accent-300 border-accent-500/20',
  phase: 'bg-blue-500/10 text-blue-300 border-blue-500/20',
  execute: 'bg-green-500/10 text-green-300 border-green-500/20',
  validate: 'bg-purple-500/10 text-purple-300 border-purple-500/20',
  reflect: 'bg-rose-500/10 text-rose-300 border-rose-500/20',
  info: 'bg-yellow-500/10 text-yellow-300 border-yellow-500/20',
  debug: 'bg-red-500/10 text-red-300 border-red-500/20',
  plan: 'bg-emerald-500/10 text-emerald-300 border-emerald-500/20',
  design: 'bg-violet-500/10 text-violet-300 border-violet-500/20',
};
---

<section id="commands" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-100">All <span class="gradient-text">commands</span> at a glance</h2>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
        From init to reflection — every SDD phase has a dedicated command.
      </p>
    </div>

    <div class="max-w-3xl mx-auto overflow-hidden rounded-xl border border-white/10 bg-white/[0.02]">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-white/5">
              <th class="text-left px-4 sm:px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500 font-mono">Command</th>
              <th class="text-left px-4 sm:px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500 font-mono hidden sm:table-cell">Description</th>
              <th class="text-right px-4 sm:px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500 font-mono">Phase</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {commands.map((cmd) => (
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-4 sm:px-6 py-3">
                  <code class="text-xs sm:text-sm font-mono text-accent-300 whitespace-nowrap">{cmd.cmd}</code>
                </td>
                <td class="px-4 sm:px-6 py-3 text-sm text-gray-400 hidden sm:table-cell">{cmd.desc}</td>
                <td class="px-4 sm:px-6 py-3 text-right">
                  {cmd.badge && (
                    <span class={`inline-block px-2 py-0.5 rounded-full text-[10px] font-mono border ${badgeColors[cmd.badge] || 'bg-gray-500/10 text-gray-400 border-gray-500/20'}`}>
                      {cmd.badge}
                    </span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
