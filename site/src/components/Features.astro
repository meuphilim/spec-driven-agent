---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

const features: Feature[] = [
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>',
    title: '5 GATEs',
    description: 'Each phase requires explicit approval. No spec → no code. No plan → no execute. Quality gates enforced by Samantha Agent.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>',
    title: 'Two modes',
    description: 'FULL (~15K tokens) for complex tasks, LITE (~1.5K) for quick ones. Automatic classification saves 60% token waste on trivial work.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>',
    title: 'Knowledge Engine',
    description: '5-layer memory system. Every session feeds the knowledge base. Patterns, heuristics, and antipatterns persist across sessions.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>',
    title: '53 Tests',
    description: '19 integration + 8 LITE + 26 unit tests. CI pipeline validates every commit. Test coverage built into the development workflow.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>',
    title: 'Samantha Agent',
    description: 'AI orchestrator managing all 7 SDD phases. Validates GATEs, monitors turns, detects scope creep. Your development copilot.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
    title: 'Ponytail Philosophy',
    description: 'YAGNI baked in. One file spec, two mode execution, zero infrastructure overhead. Productive from minute one.',
  },
];

const bentoLayout = [
  { row: 0, col: 0, span: 'col-span-1 md:col-span-1 row-span-1', feature: features[0] },
  { row: 0, col: 1, span: 'col-span-1 md:col-span-1 row-span-1', feature: features[1] },
  { row: 1, col: 0, span: 'col-span-1 md:col-span-2 row-span-1', feature: features[2] },
  { row: 1, col: 1, span: 'col-span-1 md:col-span-1 row-span-1', feature: features[3] },
  { row: 2, col: 0, span: 'col-span-1 md:col-span-1 row-span-1', feature: features[4] },
  { row: 2, col: 1, span: 'col-span-1 md:col-span-1 row-span-1', feature: features[5] },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-100">Everything you need for <span class="gradient-text">agentic discipline</span></h2>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
        From specification to reflection — SDD enforces rigor at every step.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {bentoLayout.map((item) => (
        <div class={`${item.span} group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/[0.12] transition-all duration-300 p-6`}>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-accent-500/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity" />
          <div class="relative">
            <div class="w-10 h-10 rounded-lg bg-accent-500/10 border border-accent-500/20 flex items-center justify-center text-accent-400 mb-4" set:html={item.feature.icon} />
            <h3 class="text-base font-semibold text-gray-100 mb-2">{item.feature.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{item.feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
