---
interface Feature {
  num: string;
  title: string;
  description: string;
  tag: string;
}

const features: Feature[] = [
  {
    num: '01',
    title: '5 GATEs',
    tag: 'quality',
    description: 'Each phase requires explicit approval. No spec, no code. No plan, no execute. Quality gates enforced by Samantha Agent.',
  },
  {
    num: '02',
    title: 'Two modes',
    tag: 'efficiency',
    description: 'FULL (~15K tokens) for complex tasks, LITE (~1.5K) for quick ones. Automatic classification saves 60% token waste on trivial work.',
  },
  {
    num: '03',
    title: 'Knowledge Engine',
    tag: 'memory',
    description: '5-layer memory system. Every session feeds the knowledge base. Patterns, heuristics, and antipatterns persist across sessions.',
  },
  {
    num: '04',
    title: '53 Tests',
    tag: 'coverage',
    description: '19 integration + 8 LITE + 26 unit tests. CI pipeline validates every commit. Test coverage built into the development workflow.',
  },
  {
    num: '05',
    title: 'Samantha Agent',
    tag: 'orchestration',
    description: 'AI orchestrator managing all 7 SDD phases. Validates GATEs, monitors turns, detects scope creep. Your development copilot.',
  },
  {
    num: '06',
    title: 'Ponytail Philosophy',
    tag: 'simplicity',
    description: 'YAGNI built in. One file spec, two mode execution, zero infrastructure overhead. Productive from minute one.',
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Heading — left-aligned, not centered -->
    <div class="mb-16 max-w-2xl">
      <span class="section-label">Core capabilities</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--text-primary);">
        Everything you need for<br/>
        <span class="gradient-text">agentic discipline</span>
      </h2>
      <p class="mt-4 leading-relaxed" style="color: var(--text-secondary);">
        From specification to reflection — SDD enforces rigor at every step.
      </p>
    </div>

    <!-- Zig-zag / asymmetric feature list -->
    <div class="features-list">
      {features.map((f, i) => (
        <div class={`feature-row ${i % 2 !== 0 ? 'feature-row--alt' : ''}`}>
          <div class="feature-row-num">
            <span class="feat-num">{f.num}</span>
          </div>
          <div class="feature-row-content">
            <div class="flex items-baseline gap-3 mb-2">
              <h3 class="text-xl font-semibold" style="color: var(--text-primary);">{f.title}</h3>
              <span class="feat-tag">{f.tag}</span>
            </div>
            <p class="text-sm leading-relaxed max-w-[55ch]" style="color: var(--text-secondary);">{f.description}</p>
          </div>
          <div class="feature-row-divider" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Feature rows — horizontal list with alternating indent */
  .features-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border-subtle);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    align-items: start;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border-subtle);
    transition: background-color 0.2s ease;
    position: relative;
  }

  /* Alternating indent on desktop */
  @media (min-width: 768px) {
    .features-list {
      border-top: none;
    }
    .feature-row {
      grid-template-columns: 5rem 1fr;
      padding: 2rem 1rem;
      border-radius: 0.5rem;
      border-bottom: none;
    }
    .feature-row::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 5rem;
      right: 0;
      height: 1px;
      background-color: var(--border-subtle);
    }
    .feature-row:last-child::after { display: none; }
    .feature-row--alt {
      padding-left: 3rem;
    }
    .feature-row:hover {
      background-color: var(--bg-muted);
    }
  }

  /* Number */
  .feature-row-num {
    padding-top: 0.15rem;
    display: flex;
    justify-content: flex-start;
  }
  .feat-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    font-weight: 500;
    padding-top: 0.3rem;
  }

  /* Tag pill */
  .feat-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #84cc16;
    border: 1px solid color-mix(in srgb, #84cc16 25%, transparent);
    background-color: color-mix(in srgb, #84cc16 8%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    white-space: nowrap;
    margin-bottom: 0.15rem;
  }

  .feature-row-divider { display: none; }
</style>
