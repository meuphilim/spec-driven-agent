---
const modes = [
  {
    name: 'LITE',
    label: 'Quick mode',
    tokens: '~1,500',
    savings: '60%',
    savingsColor: 'text-green-500',
    isAccent: true,
    tasks: 'P (score 0-3)',
    flow: 'CLASSIFY → EXECUTE → REFLECT',
    details: [
      'Spec inline (no file created)',
      'Plan automatic (no GATE)',
      'Reflect: 1 line',
    ],
  },
  {
    name: 'FULL',
    label: 'Full SDD',
    tokens: '~15,000',
    savings: 'Baseline',
    savingsColor: '',
    isAccent: false,
    tasks: 'M, G, XG',
    flow: 'CONSTITUTION → SPECIFY → DESIGN → PLAN → EXECUTE → VALIDATE → REFLECT',
    details: [
      'Spec file with acceptance criteria',
      '5 GATEs: SPEC → DESIGN → PLAN → VALIDATE → REFLECT',
      'Samantha orchestrates all transitions',
    ],
  },
];
---

<section id="modes" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--text-primary);">Two modes. One framework.</h2>
      <p class="mt-4 max-w-2xl mx-auto" style="color: var(--text-secondary);">
        Automatic task classification routes each job to the right workflow.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {modes.map((mode) => (
        <div class={`mode-card relative overflow-hidden rounded-xl p-6 sm:p-8 transition-all duration-300 hover:scale-[1.02] ${mode.isAccent ? 'mode-card--accent' : ''}`}>
          {mode.isAccent && <div class="mode-glow absolute top-0 right-0 w-48 h-48 rounded-full blur-3xl pointer-events-none" />}
          <div class="relative">
            <div class="flex items-center justify-between mb-4">
              <span class={`mode-badge inline-flex items-center px-3 py-1 rounded-full text-xs font-mono font-semibold ${mode.isAccent ? 'mode-badge--accent' : 'mode-badge--default'}`}>
                {mode.name}
              </span>
              <span class="text-xs font-mono" style="color: var(--text-muted);">{mode.tokens}</span>
            </div>

            <h3 class="text-lg font-semibold mb-1" style="color: var(--text-primary);">{mode.label}</h3>

            <div class="flex items-center gap-2 mt-3">
              <span class={`text-sm font-mono font-bold ${mode.savingsColor || ''}`} style={!mode.savingsColor ? 'color: var(--text-secondary)' : ''}>{mode.savings}</span>
              <span class="text-xs" style="color: var(--text-muted);">token savings</span>
            </div>

            <div class="mt-4 text-xs font-mono" style="color: var(--text-muted);">
              For: <span style="color: var(--text-primary);">{mode.tasks}</span>
            </div>

            <div class="mt-2 p-3 rounded-lg mode-flow-box">
              <div class="text-xs font-mono leading-relaxed" style="color: var(--text-secondary);">{mode.flow}</div>
            </div>

            <ul class="mt-4 space-y-2">
              {mode.details.map((detail) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 max-w-4xl mx-auto p-6 rounded-xl glass-card text-center">
      <p class="text-sm" style="color: var(--text-secondary);">
        <strong style="color: var(--text-primary);">Automatic detection:</strong> Effort <code class="text-accent-500 font-mono text-xs px-1 py-0.5 rounded" style="background-color: color-mix(in srgb, #84cc16 10%, transparent);">low</code> → LITE mode automatically.
        No manual switching. No configuration.
      </p>
    </div>
  </div>
</section>

<style>
  .mode-card {
    background-color: var(--bg-muted);
    border: 1px solid var(--border-subtle);
  }
  .mode-card--accent {
    background-color: color-mix(in srgb, #84cc16 3%, var(--bg-muted));
    border-color: color-mix(in srgb, #84cc16 15%, transparent);
  }
  .mode-glow {
    background: color-mix(in srgb, #84cc16 6%, transparent);
  }
  .mode-badge {
    border: 1px solid transparent;
  }
  .mode-badge--accent {
    background-color: color-mix(in srgb, #84cc16 12%, transparent);
    color: #a3e635;
    border-color: color-mix(in srgb, #84cc16 25%, transparent);
  }
  .mode-badge--default {
    background-color: color-mix(in srgb, #3b82f6 10%, transparent);
    color: #93c5fd;
    border-color: color-mix(in srgb, #3b82f6 20%, transparent);
  }
  :global(:not(.dark)) .mode-badge--default {
    color: #2563eb;
  }
  .mode-flow-box {
    background-color: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
  }
</style>
