---
const phases = [
  {
    num: '01',
    key: 'CONSTITUTION',
    label: 'Constitution',
    desc: 'Load project guardrails, stack, and conventions before any work begins.',
    color: '#84cc16',
    gate: null,
  },
  {
    num: '02',
    key: 'SPECIFY',
    label: 'Specify',
    desc: 'Generate a spec file with acceptance criteria and scope boundaries.',
    color: '#7aa2f7',
    gate: 'SPEC GATE',
  },
  {
    num: '03',
    key: 'DESIGN',
    label: 'Design',
    desc: 'Architecture decisions, data flow, module contracts.',
    color: '#bb9af7',
    gate: 'DESIGN GATE',
  },
  {
    num: '04',
    key: 'PLAN',
    label: 'Plan',
    desc: 'Atomic steps per file, rollback strategy, impact analysis.',
    color: '#e0af68',
    gate: 'PLAN GATE',
  },
  {
    num: '05',
    key: 'EXECUTE',
    label: 'Execute',
    desc: 'Implement each plan step and validate inline per pass.',
    color: '#9ece6a',
    gate: null,
  },
  {
    num: '06',
    key: 'VALIDATE',
    label: 'Validate',
    desc: 'Code review against the spec acceptance criteria.',
    color: '#2ac3de',
    gate: 'VALIDATE GATE',
  },
  {
    num: '07',
    key: 'REFLECT',
    label: 'Reflect',
    desc: 'Auto-evaluation. Consolidate patterns into the knowledge base.',
    color: '#f7768e',
    gate: 'REFLECT GATE',
  },
];
---

<section id="how-it-works" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header — left aligned -->
    <div class="mb-16 max-w-2xl">
      <span class="section-label">Workflow</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--text-primary);">The SDD Cycle</h2>
      <p class="mt-4" style="color: var(--text-secondary);">
        Seven phases. Five GATEs. One orchestrated flow by
        <strong style="color: var(--text-primary);">Samantha Agent</strong>.
      </p>
    </div>

    <!-- Phase table — 2-column list on desktop -->
    <div class="cycle-grid">
      {phases.map((phase, i) => (
        <div class="cycle-row">
          <!-- Left: number + line -->
          <div class="cycle-meta">
            <span class="cycle-num" style={`color: ${phase.color};`}>{phase.num}</span>
            {i < phases.length - 1 && <span class="cycle-connector" />}
          </div>

          <!-- Right: content -->
          <div class="cycle-content">
            <div class="cycle-top">
              <span class="cycle-key" style={`color: ${phase.color};`}>{phase.key}</span>
              {phase.gate && (
                <span class="cycle-gate">{phase.gate}</span>
              )}
            </div>
            <div class="cycle-label" style="color: var(--text-primary);">{phase.label}</div>
            <p class="cycle-desc">{phase.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Summary breadcrumb -->
    <div class="mt-12 overflow-x-auto">
      <div class="summary-bar">
        {phases.map((p, i) => (
          <>
            <span class="summary-key" style={`color: ${p.color};`}>{p.key}</span>
            {i < phases.length - 1 && (
              <svg class="summary-arrow" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Grid: 2 columns on large, 1 column on small ── */
  .cycle-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .cycle-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0 4rem;
    }
  }

  /* ── Each row ── */
  .cycle-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0 1rem;
    padding-bottom: 2rem;
  }

  /* ── Left meta column ── */
  .cycle-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.1rem;
  }

  .cycle-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    flex-shrink: 0;
    line-height: 1.6;
  }

  .cycle-connector {
    flex: 1;
    width: 1px;
    background: linear-gradient(to bottom, var(--border-default) 0%, transparent 100%);
    margin-top: 0.4rem;
    min-height: 1.5rem;
  }

  /* ── Right content ── */
  .cycle-content {
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: 0.25rem;
  }

  .cycle-row:last-child .cycle-content {
    border-bottom: none;
  }

  .cycle-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.15rem;
  }

  .cycle-key {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cycle-gate {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border-default);
    background-color: var(--bg-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 0.2rem;
    white-space: nowrap;
  }

  .cycle-label {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .cycle-desc {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 42ch;
    padding-bottom: 0.75rem;
  }

  /* ── Summary breadcrumb ── */
  .summary-bar {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border-subtle);
    background-color: var(--bg-muted);
    white-space: nowrap;
  }

  .summary-key {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .summary-arrow {
    width: 14px;
    height: 14px;
    color: var(--text-faint);
    flex-shrink: 0;
  }
</style>
